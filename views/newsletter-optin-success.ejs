<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Welcome to Paper Street Thrift - Subscription Confirmed</title>
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: 'Georgia', serif;
      background-color: #F8F3EA;
      color: #1B2B38;
      line-height: 1.6;
      padding: 20px;
    }

    .container {
      max-width: 600px;
      margin: 60px auto;
      background: white;
      border-radius: 8px;
      box-shadow: 0 2px 10px rgba(27, 43, 56, 0.08);
      overflow: hidden;
    }

    .header {
      background: linear-gradient(135deg, #5AACAA 0%, #4A9C9A 100%);
      padding: 40px 30px;
      text-align: center;
      color: white;
    }

    .header h1 {
      font-size: 28px;
      font-weight: 600;
      margin-bottom: 10px;
    }

    .header p {
      font-size: 16px;
      opacity: 0.95;
    }

    .content {
      padding: 40px 30px;
    }

    .success-icon {
      text-align: center;
      margin-bottom: 30px;
    }

    .success-icon svg {
      width: 80px;
      height: 80px;
      fill: #5AACAA;
    }

    .message {
      font-size: 18px;
      text-align: center;
      margin-bottom: 30px;
      color: #1B2B38;
    }

    .message strong {
      color: #5AACAA;
    }

    .details {
      background: #F8F3EA;
      border-left: 4px solid #5AACAA;
      padding: 20px;
      margin: 30px 0;
      border-radius: 4px;
    }

    .details p {
      margin-bottom: 12px;
      font-size: 15px;
    }

    .details p:last-child {
      margin-bottom: 0;
    }

    .footer {
      text-align: center;
      padding: 30px;
      background: #F8F3EA;
      font-size: 14px;
      color: #1B2B38;
    }

    .footer p {
      margin-bottom: 8px;
    }

    .footer a {
      color: #5AACAA;
      text-decoration: none;
      font-weight: 500;
    }

    .footer a:hover {
      text-decoration: underline;
    }

    .checkmark-circle {
      stroke-dasharray: 166;
      stroke-dashoffset: 166;
      animation: stroke 0.6s cubic-bezier(0.65, 0, 0.45, 1) forwards;
    }

    .checkmark {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      display: block;
      stroke-width: 3;
      stroke: #5AACAA;
      stroke-miterlimit: 10;
      margin: 0 auto;
      box-shadow: inset 0px 0px 0px #5AACAA;
      animation: fill 0.4s ease-in-out 0.4s forwards, scale 0.3s ease-in-out 0.9s both;
    }

    .checkmark-check {
      transform-origin: 50% 50%;
      stroke-dasharray: 48;
      stroke-dashoffset: 48;
      animation: stroke 0.3s cubic-bezier(0.65, 0, 0.45, 1) 0.8s forwards;
    }

    @keyframes stroke {
      100% {
        stroke-dashoffset: 0;
      }
    }

    @keyframes scale {
      0%, 100% {
        transform: none;
      }
      50% {
        transform: scale3d(1.1, 1.1, 1);
      }
    }

    @keyframes fill {
      100% {
        box-shadow: inset 0px 0px 0px 40px #5AACAA;
      }
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Welcome to Paper Street Thrift!</h1>
      <p>You're all set</p>
    </div>

    <div class="content">
      <div class="success-icon">
        <svg class="checkmark" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 52 52">
          <circle class="checkmark-circle" cx="26" cy="26" r="25" fill="none"/>
          <path class="checkmark-check" fill="none" d="M14.1 27.2l7.1 7.2 16.7-16.8"/>
        </svg>
      </div>

      <div class="message">
        <p><strong>Thank you<% if (firstName) { %>, <%= firstName %><% } %>!</strong></p>
        <p>Your subscription has been confirmed.</p>
      </div>

      <div class="details">
        <p><strong>What happens next?</strong></p>
        <p>You'll receive occasional emails from Paper Street Thrift featuring:</p>
        <ul style="margin-left: 20px; margin-top: 10px;">
          <li>New arrivals and curated collections</li>
          <li>Special offers and member-only discounts</li>
          <li>Updates on sales and events</li>
        </ul>
      </div>

      <div class="message" style="margin-top: 30px; font-size: 16px;">
        <p>We're glad to have you with us!</p>
      </div>
    </div>

    <div class="footer">
      <p><strong>Paper Street Thrift</strong></p>
      <p>Quality secondhand goods with character</p>
    </div>
  </div>
</body>
</html>
