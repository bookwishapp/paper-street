# Database (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql://user:password@host:port/database

# Square API
SQUARE_ACCESS_TOKEN=your_square_access_token_here

# New York Times Books API
NYT_API_KEY=your_nyt_api_key_here

# AWS SES Email Configuration
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
SES_FROM_EMAIL=hello@sinclairinlet.com

# Admin Authentication
ADMIN_PASSWORD=your_secure_admin_password_here

# Session Configuration (optional, defaults to built-in)
SESSION_SECRET=your_session_secret_key_here

# Website URL (optional, defaults to https://sinclairinlet.com)
WEBSITE_URL=https://sinclairinlet.com

# Categories for Paper Street Thrift inventory
PAPER_STREET_CATEGORIES=Games,Puzzles,Art Supplies,Stationery,Paper Goods

# Server Configuration (Railway provides PORT automatically)
PORT=3000
NODE_ENV=development